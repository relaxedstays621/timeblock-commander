# ─────────────────────────────────────────────────────────
# TimeBlock Commander — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Database (Postgres inside Docker — this default works out of the box)
DATABASE_URL="postgresql://timeblock:timeblock_secret@localhost:5433/timeblock?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3100"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (Phase 2 — leave blank for now, app works without it)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI (Phase 4 — leave blank for now)
OPENAI_API_KEY=""

# n8n Webhooks (Phase 3 — leave blank for now)
N8N_WEBHOOK_BASE_URL=""
N8N_TASK_CREATED_WEBHOOK=""
N8N_SCHEDULE_CHANGED_WEBHOOK=""

# Server
PORT=3100
NODE_ENV=production
