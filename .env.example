# ─────────────────────────────────────────────────────────────────────────────
# TimeBlock Commander — Environment Variables
# Copy this file to .env and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for Docker/runtime ─────────────────────────────────────────────
# `docker compose up` will refuse to start if any of these are missing or empty.

# Database password for the `timeblock` Postgres user.
# Read by BOTH the db service (POSTGRES_PASSWORD) and the app service
# (synthesized DATABASE_URL → db:5432 inside the docker network).
# After the db volume is first initialized, this value is baked into the
# persistent volume; rotating it on the live DB requires an ALTER USER.
DB_PASSWORD=""

# Public origin where the app is reachable. NextAuth uses this to build the
# OAuth callback URL. Mismatches here are a common cause of `?error=Callback`.
# Examples: "http://localhost:3100", "https://time.example.com"
NEXTAUTH_URL=""

# Session signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ── Required for Google sign-in in production ───────────────────────────────
# Both must be set for the Google OAuth provider to function. The app will
# still boot without them; Google sign-in is simply unavailable.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Optional integrations ───────────────────────────────────────────────────
# Leave blank if not wired up.

OPENAI_API_KEY=""

N8N_WEBHOOK_BASE_URL=""
N8N_TASK_CREATED_WEBHOOK=""
N8N_SCHEDULE_CHANGED_WEBHOOK=""

# ── Host-side Prisma CLI ────────────────────────────────────────────────────
# Used by `npx prisma ...` commands run from the host machine — NOT by the
# app container. The app container builds its own DATABASE_URL internally
# from DB_PASSWORD above and connects to the db service over the docker
# network at db:5432.
#
# The host reaches the same DB through the published port (5433), so the
# password in this URL must match DB_PASSWORD above. If they diverge,
# host-side Prisma CLI commands will fail with a P1000 auth error while the
# app container continues to work fine.

DATABASE_URL="postgresql://timeblock:CHANGE_ME@localhost:5433/timeblock?schema=public"

# ── Host-side server defaults (ignored by the docker app container) ─────────
# The docker app container hard-codes PORT=3100 and NODE_ENV=production in
# docker-compose.yml; these entries only affect host-side `npm` invocations.

PORT=3100
NODE_ENV=production
